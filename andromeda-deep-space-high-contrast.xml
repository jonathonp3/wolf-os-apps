<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="andromeda-deep-space-high-contrast" _name="Andromeda (High Contrast)" version="1.0">
  <author>Eliver Lara / Jonathon</author>
  <_description>Aggressive high-contrast space theme with glowing neon accents</_description>

  <!-- Andromeda High Contrast Palette -->
  <color name="andromeda-bg"      value="#0c0e14"/> <!-- Deep Midnight Space (Darker) -->
  <color name="andromeda-fg"      value="#ffffff"/> <!-- Pure White Text -->
  <color name="andromeda-line"    value="#161b22"/> <!-- Subtle Current Line -->
  <color name="andromeda-sel"     value="#2d333b"/> <!-- Higher Contrast Selection -->
  
  <color name="andromeda-pink"    value="#ff007f"/> <!-- Electric Pink -->
  <color name="andromeda-orange"  value="#ff9c00"/> <!-- Vivid Orange -->
  <color name="andromeda-yellow"  value="#ffff00"/> <!-- Neon Yellow -->
  <color name="andromeda-green"   value="#39ff14"/> <!-- Matrix Green -->
  <color name="andromeda-cyan"    value="#00f2ff"/> <!-- High Contrast Cyan -->
  <color name="andromeda-blue"    value="#00bfff"/> <!-- Sky Blue -->
  <color name="andromeda-gray"    value="#8b949e"/> <!-- Brighter Comments for clarity -->
  <color name="andromeda-red"     value="#ff2e44"/> <!-- Power Red -->

  <!-- Global Settings -->
  <style name="text"                        foreground="andromeda-fg" background="andromeda-bg"/>
  <style name="selection"                   background="andromeda-sel"/>
  <style name="cursor"                      foreground="andromeda-cyan"/>
  <style name="current-line"                background="andromeda-line"/>
  <style name="line-numbers"                foreground="andromeda-gray" background="#050608"/>
  <style name="draw-spaces"                 foreground="#3e4451"/>

  <!-- Syntax Highlighting -->
  <style name="def:comment"                 foreground="andromeda-gray" italic="true"/>
  <style name="def:constant"                foreground="andromeda-green" bold="true"/>
  <style name="def:special-char"            foreground="andromeda-pink"/>
  <style name="def:identifier"              foreground="andromeda-cyan"/>
  <style name="def:function"                foreground="andromeda-blue" bold="true"/>
  
  <!-- Main Statements: The High Contrast Punch -->
  <style name="def:statement"               foreground="andromeda-orange" bold="true"/>
  <style name="def:keyword"                 foreground="andromeda-pink" bold="true"/>
  
  <style name="def:type"                    foreground="andromeda-yellow" bold="true"/>
  <style name="def:operator"                foreground="andromeda-cyan" bold="false"/>
  <style name="def:preprocessor"            foreground="andromeda-blue"/>
  <style name="def:error"                   foreground="andromeda-red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="andromeda-green" bold="true"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="andromeda-blue" underline="single"/>
  <style name="def:heading"                 foreground="andromeda-pink" bold="true"/>
</style-scheme>

